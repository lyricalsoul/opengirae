# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://girae:girae@localhost:5433/girae"

ORIGIN="http://localhost:5173"

# Telegram Mini App auth (telegramProcedure validates initData against this) - same bot token
# telegram-inbound uses, from the repo root .env. website/ has its own .env (separate cwd for
# bun/vite), so it doesn't inherit the root one - this needs to be copied here explicitly.
TELEGRAM_TOKEN=

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=

# OIDC (generic OAuth)
OIDC_DISCOVERY_URL="https://auth.girae.io/.well-known/openid-configuration"
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

DITTO_URL=
DITTO_API_KEY=
