{
  "name": "opengirae",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/**"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.23.6",
    "@dbos-inc/drizzle-datasource": "^4.23.6",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^5.1.0",
    "pg": "^8.22.0",
    "telegramsjs": "^4.14.1"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "bun packages/database/seed.ts",
    "dev:all": "bun run --parallel 'dev:inbounder' 'dev:commandeer' 'dev:answerer'",
    "dev:inbounder": "bun --watch packages/inbounder/index.ts",
    "dev:commandeer": "bun --watch packages/commandeer/index.ts",
    "dev:answerer": "bun --watch packages/answerer/index.ts"
  }
}